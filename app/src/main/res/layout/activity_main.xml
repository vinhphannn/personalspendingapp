<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Container for custom Input Tabs (Tiền Chi, Tiền Thu) -->
    <!-- This LinearLayout will contain two custom text views acting as tabs -->
    <LinearLayout
        android:id="@+id/inputTabsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical" >

        <!-- Custom Tab for Tiền Chi -->
        <TextView
            android:id="@+id/tvTabExpense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TIỀN CHI"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="?attr/selectableItemBackground"/>

        <!-- Custom Tab for Tiền Thu -->
        <TextView
            android:id="@+id/tvTabIncome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TIỀN THU"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
             android:background="?attr/selectableItemBackground"/>

    </LinearLayout>

    <!-- ViewPager2 to display all fragments - Always visible and takes remaining space -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom Navigation View - Always visible at the bottom -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>